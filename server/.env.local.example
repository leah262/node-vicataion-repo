# העתיקי לקובץ .env.local (או החליפי זמנית את .env) — MySQL מקומי
PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=vacation_rentals

# ללא SSL במקומי — השאירי ריק או OFF
DB_SSL_MODE=OFF

# JWT — לאוטנטיקציה. צרי ערך אקראי:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please-change-me
JWT_EXPIRES_IN=7d
