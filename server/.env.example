# Server
PORT=5000

# MySQL (Railway)
# `*.railway.internal` — רק כשהאפליקציה רצה על Railway. במחשב מקומי: שימוש ב־hostname הציבורי מ־DATABASE_URL (למשל *.proxy.rlwy.net), או הגדרת DB_HOST ידנית.
# אם DB_HOST נשאר internal וקיים DATABASE_URL ציבורי — השרת יחליף אוטומטית ל־host מה־URL (ראו db.js).
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=railway
DB_SSL_MODE=REQUIRED

# Full connection URI (optional - used as fallback)
DATABASE_URL=mysql://root:change-me@your-host.proxy.rlwy.net:00000/railway

# JWT — לאוטנטיקציה (צרי ערך אקראי ארוך; לא לשתף בין סביבות)
JWT_SECRET=please-generate-with-openssl-rand-hex-48
JWT_EXPIRES_IN=7d

# SMTP — לשליחת מיילים (מייל ברוכים-הבאים בהרשמה)
# לדוגמה עבור Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_USER=האימייל-שלך,
# SMTP_PASS=App Password (לא הסיסמה הרגילה!). יש ליצור App Password בהגדרות חשבון Google.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Your App Name <your-email@gmail.com>
SMTP_TLS_INSECURE=true

# כתובת בסיס של אתר הלקוח (SPA) — לבניית קישורים במיילים (/verify-email, /apartments/…).
# אופציונלי: אם ריק, קישורים במייל ישתמשו בבסיס כתובת ה-API (אותו מארח כמו השרת, בלי /api).
# דוגמה כשיש פרונטאנד נפרד: APP_URL=https://your-site.example.com
# APP_URL=

# בסיס ה-API הציבורי (חייב להסתיים ב־/api). לקישורי אישור מייל וכו׳.
# בפרודקשן מומלץ במפורש, למשל: PUBLIC_API_URL=https://api.example.com/api
# מקומית, אם לא מוגדר: http://127.0.0.1:PORT/api
# PUBLIC_API_URL=

# Railway: אם מוגדר RAILWAY_PUBLIC_DOMAIN (hostname בלי https), PUBLIC_API_URL ייבנה אוטומטית.

# CORS בפיתוח: מותר מארח ה-API + מה שב־CORS_ORIGINS. להוספת SPA על פורט אחר:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CSP בפיתוח (connect-src): מותר ה-API + ערכים מ־CSP_DEV_EXTRA_CONNECT (מופרד בפסיקים)
# CSP_DEV_EXTRA_CONNECT=http://localhost:3000,ws://localhost:3000

# תזכורת ראשונה: כמה ימים לפני פקיעת התוקף לשלוח אותה (ברירת מחדל: 7).
EXPIRY_REMINDER_DAYS=7
# תזכורת אחרונה: כמה ימים לפני הפקיעה לשלוח תזכורת נוספת אם לא חודשה (ברירת מחדל: 1).
EXPIRY_FINAL_REMINDER_DAYS=1

# התחברות עם גוגל — Client ID מ-Google Cloud Console (OAuth 2.0).
# יש ליצור OAuth Client (Web) ולהוסיף את כתובת האתר ל-Authorized JavaScript origins.
# כל עוד ריק — כפתור "התחברות עם Google" יהיה מוסתר והתחברות גוגל מושבתת.
GOOGLE_CLIENT_ID=

# כתובת לקבלת התראות מנהל (פרסום דירה חדשה / פניות "צור קשר"). ניתן לפצל בכמה כתובות עם פסיק.
ADMIN_NOTIFY_EMAIL=admin@example.com

# חשבון מנהל — נוצר אוטומטית בעליית השרת אם המייל לא קיים עדיין.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisStrongPassword!

# ────────── Cloudinary (תמונות — ללא שמירה על דיסק השרת) ──────────
# אפשרות א׳: מחרוזת אחת מהדשבורד (מומלץ)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# אפשרות ב׳:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# תיקייה אופציונלית ב-Cloudinary (ללא slashes מיותרים)
# CLOUDINARY_UPLOAD_FOLDER=vacation-rentals

# ────────── PayPal (Orders API — server-side secret) ──────────
# Sandbox app: https://developer.paypal.com/dashboard/applications/sandbox
# Client ID גם בפרונטאנד (משתנה ציבורי, למשל VITE_PAYPAL_CLIENT_ID).
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# PAYPAL_TLS_INSECURE: false = אימות TLS מלא. true = ללא אימות תעודה מול PayPal.
# בפיתוח מקומי (לא ענן, NODE_ENV לא production) — ברירת מחדל כבר עוקפת TLS; אפשר PAYPAL_TLS_INSECURE=false לכיבוי.
# PAYPAL_TLS_INSECURE=true
# Optional. Omit = Sandbox: https://api-m.sandbox.paypal.com
# PAYPAL_API_BASE=https://api-m.paypal.com

# ────────── PayMe (server-side only — never put secrets in VITE_*) ──────────
# TODO: Fill real values from PayMe dashboard / official docs.
# If PayMe does not use separate API key vs secret, you can leave one blank and adjust paymeService headers.
PAYME_API_KEY=
PAYME_SECRET=
PAYME_MERCHANT_ID=
PAYME_BASE_URL=
PAYME_WEBHOOK_SECRET=
# Optional overrides for endpoint paths (defaults are generic placeholders):
# PAYME_CREATE_PAYMENT_PATH=/payments
# PAYME_GET_STATUS_PATH=/payments/:id
# PAYME_VERIFY_PAYMENT_PATH=/payments/:id/verify
# PAYME_HTTP_TIMEOUT_MS=20000
# Optional: tighten create endpoint rate limit (per IP / 15 minutes)
# RATE_LIMIT_PAYME_CREATE_MAX=60
